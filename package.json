{
  "name": "xypriss-compression",
  "version": "1.0.5",
  "description": "Advanced Go-powered compression middleware for XyPriss, delivering high-performance stream processing and security-hardened header management.",
  "author": {
    "name": "Nehonix Team",
    "url": "https://nehonix.com"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "scripts"
  ],
  "engines": {
    "node": ">= 14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nehonix-Team/xypriss-compression.git"
  },
  "keywords": [
    "compression",
    "gzip",
    "deflate",
    "brotli",
    "br",
    "middleware",
    "express",
    "xypriss",
    "http",
    "stream",
    "algorithm-enforcement",
    "typescript",
    "nehonix",
    "xypriss-compression"
  ],
  "scripts": {
    "build": "xfpm run build:go && tsc",
    "build:go": "bun run scripts/build-xlibc.ts",
    "dev": "tsc --watch",
    "postinstall": "node scripts/install-xlibc.js",
    "prepublishOnly": "xfpm run build"
  },
  "dependencies": {
    "bytes": "^3.1.2",
    "xypriss-on-headers": "^2.0.1",
    "xypriss-vary": "^1.1.3-xypriss"
  },
  "devDependencies": {
    "@types/bytes": "^3.1.4",
    "@types/compressible": "^2.0.2",
    "@types/mime-db": "^1.27.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
