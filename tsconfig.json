{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    // "rootDir": "./src",
    "rootDirs": ["./src", "./pkgs"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "on-headers": ["pkgs/on-headers/index.ts"]
    }
  },
  "include": ["src/**/*", "pkgs"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
